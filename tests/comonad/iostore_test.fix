main: IO ();
main = (
    [
        test_iostore_make_run_io_store,
        test_iostore_functor,
        test_iostore_extract,
        test_iostore_extend,
        //test_iostore_comonad_laws,
        TestCase::empty
    ]
    .run_test_driver
);


